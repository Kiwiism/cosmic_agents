{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/agent-soak-population-preset.schema.json",
  "title": "Agent Soak Population Preset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "preset",
    "description",
    "seedPolicy",
    "defaultSeed",
    "targetAgentCount",
    "levelBands",
    "regions",
    "jobs",
    "archetypes",
    "roles",
    "cohorts",
    "mapCapacityPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "preset": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "seedPolicy": {
      "type": "string",
      "enum": [
        "explicit",
        "run-id-derived"
      ]
    },
    "defaultSeed": {
      "type": "integer"
    },
    "targetAgentCount": {
      "type": "integer",
      "minimum": 1
    },
    "levelBands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/weightedRange"
      }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/weightedRegion"
      }
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/weightedName"
      }
    },
    "archetypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/weightedName"
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/weightedName"
      }
    },
    "cohorts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cohort"
      }
    },
    "mapCapacityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultSoftAgentCap",
        "defaultHardAgentCap",
        "townSoftAgentCap",
        "trainingMapSoftAgentCap",
        "respectCatalogCaps"
      ],
      "properties": {
        "defaultSoftAgentCap": { "type": "integer", "minimum": 0 },
        "defaultHardAgentCap": { "type": "integer", "minimum": 0 },
        "townSoftAgentCap": { "type": "integer", "minimum": 0 },
        "trainingMapSoftAgentCap": { "type": "integer", "minimum": 0 },
        "respectCatalogCaps": { "type": "boolean" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ratioTolerance": { "type": "number", "minimum": 0 },
        "requiresMapCatalog": { "type": "boolean" },
        "requiresPlanCatalog": { "type": "boolean" },
        "requiresProfileTemplates": { "type": "boolean" }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "weightedName": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ratio"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "weightedRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ratio",
        "minLevel",
        "maxLevel"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "minLevel": { "type": "integer", "minimum": 1 },
        "maxLevel": { "type": "integer", "minimum": 1 }
      }
    },
    "weightedRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regionId",
        "ratio",
        "homeMapIds"
      ],
      "properties": {
        "regionId": { "type": "string", "minLength": 1 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "homeMapIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        }
      }
    },
    "cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cohortId",
        "ratio",
        "profileTemplateIds",
        "planSetIds",
        "preferredMapIds",
        "economicRoleTags"
      ],
      "properties": {
        "cohortId": { "type": "string", "minLength": 1 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "profileTemplateIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "planSetIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "hardConstraintRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "preferredMapIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "forbiddenMapIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "economicRoleTags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
