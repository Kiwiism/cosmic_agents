{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/agent-soak-scenario-manifest.schema.json",
  "title": "Agent Soak Scenario Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenario",
    "description",
    "requires",
    "durationMs",
    "captureIntervalMs",
    "waves",
    "safetyLimits"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1,
      "description": "Optional default scale stage such as 50, 250, 500, 1000, or 2000 agents."
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "targetAgentCount": {
      "type": "integer",
      "minimum": 1
    },
    "durationMs": {
      "type": "integer",
      "minimum": 1000
    },
    "captureIntervalMs": {
      "type": "integer",
      "minimum": 1000
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/wave"
      }
    },
    "safetyLimits": {
      "$ref": "#/$defs/safetyLimits"
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "snapshotsJsonl": { "type": "string", "minLength": 1 },
        "metricsCsv": { "type": "string", "minLength": 1 },
        "eventsJsonl": { "type": "string", "minLength": 1 },
        "summaryJson": { "type": "string", "minLength": 1 },
        "failuresJson": { "type": "string", "minLength": 1 }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean"
        ]
      }
    }
  },
  "$defs": {
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ratio",
        "delayWindowMs",
        "maxSpawnPerMinute"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "targetCount": {
          "type": "integer",
          "minimum": 0
        },
        "delayWindowMs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "maxSpawnPerMinute": {
          "type": "integer",
          "minimum": 1
        },
        "mapCapsRequired": {
          "type": "boolean",
          "default": true
        },
        "abortFailureThreshold": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "safetyLimits": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "integer",
          "number",
          "boolean",
          "string"
        ]
      },
      "required": [
        "maxDbWaitingSamples",
        "maxMaterializationFailures",
        "maxInvalidPositions",
        "maxSchedulerDelayP99Ms"
      ],
      "properties": {
        "maxDbWaitingSamples": { "type": "integer", "minimum": 0 },
        "maxMaterializationFailures": { "type": "integer", "minimum": 0 },
        "maxInvalidPositions": { "type": "integer", "minimum": 0 },
        "maxSchedulerDelayP99Ms": { "type": "integer", "minimum": 0 },
        "maxAgentTickP95Ms": { "type": "integer", "minimum": 0 },
        "maxHeapGrowthMbPerHour": { "type": "number", "minimum": 0 },
        "maxInventoryReconciliationFailures": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
