{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/catalog-platform/catalog-source-hashes.schema.json",
  "title": "Catalog Source Hashes Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "bundleId",
    "generatedAt",
    "hashAlgorithm",
    "sources",
    "builder"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "hashAlgorithm": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sourceHash"
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "version",
        "configHash"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "configHash": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "$defs": {
    "sourceHash": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind",
        "path",
        "hash",
        "fileCount"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
