{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/catalog-platform/catalog-compatibility-report.schema.json",
  "title": "Catalog Compatibility Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "bundleId",
    "generatedAt",
    "status",
    "requiresServerAdapterVersion",
    "requiresCatalogRuntimeVersion",
    "checks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "compatible",
        "compatible-with-warnings",
        "inspection-only",
        "blocked"
      ]
    },
    "requiresServerAdapterVersion": {
      "type": "string",
      "minLength": 1
    },
    "requiresCatalogRuntimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "status",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL",
              "SKIP"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
