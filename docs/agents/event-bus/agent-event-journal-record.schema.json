{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/event-bus/agent-event-journal-record.schema.json",
  "title": "Agent Event Journal Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "agentId",
    "occurredAtMs",
    "type",
    "context",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "agentId": {
      "type": "integer",
      "minimum": 1
    },
    "occurredAtMs": {
      "type": "integer",
      "minimum": 0
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "sourceCapability",
        "correlationId",
        "causationId",
        "objectiveId",
        "mapId"
      ],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "minimum": 1
        },
        "sourceCapability": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string"
        },
        "causationId": {
          "type": "string"
        },
        "objectiveId": {
          "type": "string"
        },
        "mapId": {
          "type": "integer",
          "minimum": -1
        }
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
