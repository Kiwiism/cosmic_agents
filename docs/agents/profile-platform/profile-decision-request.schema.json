{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/profile-platform/profile-decision-request.schema.json",
  "title": "Profile Decision Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "requestId",
    "agentId",
    "decisionKind",
    "task",
    "context",
    "requestedAtMs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "agentId": {
      "type": ["integer", "string"]
    },
    "decisionKind": {
      "type": "string",
      "enum": [
        "npc-interaction",
        "route-preference",
        "combat-risk",
        "market-action",
        "equipment-acquisition",
        "build-progression",
        "relationship-action",
        "trade-counterparty",
        "party-or-help-request",
        "task-fit",
        "micro-behavior"
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profileSummary": {
          "$ref": "agent-profile-summary.schema.json"
        },
        "buildIntent": {
          "type": "object",
          "additionalProperties": true
        },
        "location": {
          "type": "object",
          "additionalProperties": true
        },
        "catalog": {
          "type": "object",
          "additionalProperties": true
        },
        "live": {
          "type": "object",
          "additionalProperties": true
        },
        "memory": {
          "type": "object",
          "additionalProperties": true
        },
        "relationship": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "requestedBy": {
      "type": "string"
    },
    "requestedAtMs": {
      "type": "integer",
      "minimum": 0
    }
  }
}
