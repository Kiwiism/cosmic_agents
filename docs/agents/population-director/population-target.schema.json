{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-agents.local/schemas/population-target.schema.json",
  "title": "Population Target And Cohort",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "targetId",
    "ratio",
    "cohortIds",
    "regionIds",
    "levelRange",
    "jobGroups",
    "roleWeights"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "targetId": { "type": "string", "minLength": 1 },
    "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "minCount": { "type": "integer", "minimum": 0 },
    "maxCount": { "type": "integer", "minimum": 0 },
    "cohortIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "regionIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "levelRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      }
    },
    "jobGroups": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "roleWeights": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  },
  "$defs": {
    "cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "cohortId",
        "profileTemplateIds",
        "planSetIds",
        "preferredMapIds",
        "economicRoleTags"
      ],
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "cohortId": { "type": "string", "minLength": 1 },
        "profileTemplateIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "planSetIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "hardConstraintRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "preferredMapIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "forbiddenMapIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "economicRoleTags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
